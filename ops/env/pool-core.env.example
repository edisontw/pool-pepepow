# PEPEPOW pool-core snapshot producer environment.
# Configure the same RPC values in ~/.PEPEPOWcore/PEPEPOW.conf, then stop and
# start PEPEPOWd so the RPC service comes up with the new settings.

PEPEPOW_POOL_CORE_COIN_NAME=PEPEPOW
PEPEPOW_POOL_CORE_ALGORITHM=hoohashv110-pepew
PEPEPOW_POOL_CORE_FEE_PERCENT=1.0
PEPEPOW_POOL_CORE_MIN_PAYOUT=10.0
PEPEPOW_POOL_CORE_STRATUM_HOST=pool.example.com
PEPEPOW_POOL_CORE_STRATUM_PORT=3333
PEPEPOW_POOL_CORE_STRATUM_TLS=false
PEPEPOW_POOL_CORE_STRATUM_BIND_HOST=0.0.0.0
PEPEPOW_POOL_CORE_STRATUM_BIND_PORT=3333

PEPEPOWD_RPC_HOST=127.0.0.1
PEPEPOWD_RPC_PORT=8834
PEPEPOWD_RPC_URL=http://127.0.0.1:8834
PEPEPOWD_RPC_USER=change-me
PEPEPOWD_RPC_PASSWORD=change-me
PEPEPOWD_RPC_TIMEOUT_SECONDS=5

PEPEPOW_POOL_CORE_SNAPSHOT_OUTPUT=/var/lib/pepepow-pool/pool-snapshot.json
PEPEPOW_POOL_CORE_ACTIVITY_LOG_PATH=/var/lib/pepepow-pool/share-events.jsonl
PEPEPOW_POOL_CORE_ACTIVITY_SNAPSHOT_OUTPUT=/var/lib/pepepow-pool/activity-snapshot.json
PEPEPOW_POOL_CORE_ACTIVITY_WINDOW_SECONDS=900
PEPEPOW_POOL_CORE_ACTIVITY_MODE=testing-local-ingest
PEPEPOW_POOL_CORE_ACTIVITY_SNAPSHOT_INTERVAL_SECONDS=1
PEPEPOW_POOL_CORE_STRATUM_QUEUE_MAXSIZE=50000
PEPEPOW_POOL_CORE_HASHRATE_ASSUMED_SHARE_DIFFICULTY=1.0
PEPEPOW_POOL_CORE_SYNTHETIC_JOB_INTERVAL_SECONDS=30
PEPEPOW_POOL_CORE_TEMPLATE_MODE=synthetic
PEPEPOW_POOL_CORE_TEMPLATE_FETCH_INTERVAL_SECONDS=15
PEPEPOW_POOL_CORE_TEMPLATE_JOB_TTL_SECONDS=180
PEPEPOW_POOL_CORE_TEMPLATE_JOB_CACHE_SIZE=64
PEPEPOW_POOL_CORE_ACTIVITY_LOG_ROTATE_BYTES=33554432
PEPEPOW_POOL_CORE_ACTIVITY_LOG_RETENTION_FILES=8
PEPEPOW_POOL_CORE_INTERVAL_SECONDS=60
PEPEPOW_POOL_CORE_RPC_CACHE_TTL_SECONDS=5
PEPEPOW_POOL_CORE_RECENT_BLOCKS_LIMIT=10
PEPEPOW_POOL_CORE_STALE_AFTER_SECONDS=180
PEPEPOW_POOL_CORE_PRODUCER_NAME=pepepow-pool-core
