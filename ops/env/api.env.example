# Environment for the public API service.

PEPEPOW_POOL_API_HOST=127.0.0.1
PEPEPOW_POOL_API_PORT=8080
PEPEPOW_POOL_API_VERSION=0.3.0-runtime-activity
PEPEPOW_POOL_API_RUNTIME_SNAPSHOT_PATH=/var/lib/pepepow-pool/pool-snapshot.json
PEPEPOW_POOL_API_FALLBACK_SNAPSHOT_PATH=/opt/pepepow-pool/apps/api/data/mock/pool-snapshot.json
PEPEPOW_POOL_API_ACTIVITY_SNAPSHOT_PATH=/var/lib/pepepow-pool/activity-snapshot.json
PEPEPOW_POOL_API_CACHE_TTL_SECONDS=15
PEPEPOW_POOL_API_STALE_AFTER_SECONDS=180
PEPEPOW_POOL_API_ALLOWED_WALLET_PATTERN=^[A-Za-z0-9]{26,128}$
