# Root deployment defaults for the PEPEPOW MVP skeleton.

DEPLOY_ROOT=/opt/pepepow-pool
DEPLOY_USER=pepepow
PUBLIC_DOMAIN=pool.example.com
PUBLIC_API_BASE_URL=https://pool.example.com/api
POOL_COIN=PEPEPOW
POOL_ALGORITHM=hoohashv110-pepew
POOL_STRATUM_PORT=3333

# Keep internal services private.
DAEMON_RPC_BIND=127.0.0.1
REDIS_BIND=127.0.0.1
